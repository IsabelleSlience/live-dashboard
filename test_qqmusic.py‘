import subprocess

def run(script: str):
    result = subprocess.run(
        ["osascript", "-e", script],
        capture_output=True,
        text=True
    )
    if result.returncode != 0:
        print("ERR:", result.stderr.strip())
        return None
    return result.stdout.strip()

